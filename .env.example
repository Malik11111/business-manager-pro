# ─────────────────────────────────────────────────────────
# Variables d'environnement — Business Manager Pro
# Copiez ce fichier en .env pour le développement local.
# En production (Railway), définissez ces variables dans
# le dashboard : Settings > Variables
# ─────────────────────────────────────────────────────────

# OBLIGATOIRE — Clé secrète Flask (sessions, cookies)
# Générez-en une avec :
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# OBLIGATOIRE en production — URL PostgreSQL
# Railway l'injecte automatiquement si vous avez un plugin PostgreSQL.
# En développement local, laissez vide pour utiliser SQLite.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optionnel — Environnement Flask (production | development)
# FLASK_ENV=production
